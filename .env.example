# Application Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Rate Limiting Configuration
# RATE_LIMIT_WINDOW_MS: Time window in milliseconds (900000 = 15 minutes)
# RATE_LIMIT_MAX_REQUESTS: Maximum requests allowed per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT Authentication
# JWT_SECRET: Must be a strong random string in production (minimum 32 characters)
# JWT_EXPIRY: Token expiry duration (e.g., 24h, 7d, 30d)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# CORS Configuration
# CORS_ORIGIN: Allowed origin for cross-origin requests
CORS_ORIGIN=http://localhost:3000
